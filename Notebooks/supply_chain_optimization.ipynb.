        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Flag Stock Integrity exceptions based on our metrics\n",
        "merged['Stock_Status'] = np.where(merged['Units_On_Hand'] < merged['Reorder_Point'], '🔴 Critical Restock Required', '🟢 Optimized Runway')\n",
        "\n",
        "# Calculate Capital Tied Up in Warehouses (Units on Hand * Unit Cost)\n",
        "merged['Capital_Tied_Up'] = merged['Units_On_Hand'] * merged['Unit_Cost']\n",
        "\n",
        "# Visualize Exception Alert Volume across regions\n",
        "plt.figure(figsize=(8, 4))\n",
        "sns.countplot(data=merged, x='Warehouse_ID', hue='Stock_Status', palette=['crimson', 'seagreen'])\n",
        "plt.title(\"Operational Triage: Inventory Alerts by Regional Distribution Center\")\n",
        "plt.xlabel(\"Warehouse Hub Location\")\n",
        "plt.ylabel(\"System Logs Count\")\n",
        "plt.grid(axis='y', alpha=0.3)\n",
        "plt.legend(title=\"Inventory Health State\")\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n⚠️ SUMMARY REPORT FOR INVENTORY CONTROLLERS:\")\n",
        "critical_cases = merged[merged['Stock_Status'] == '🔴 Critical Restock Required']\n",
        "print(f\"Total entries breached below Safety Reorder Points: {len(critical_cases)} logs\")\n",
        "print(f\"Total Corporate Capital Stagnant in Storage Units: ${merged['Capital_Tied_Up'].sum():,.2f}\")"
