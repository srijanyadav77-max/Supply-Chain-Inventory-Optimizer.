      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "from datetime import datetime, timedelta\n",
        "\n",
        "# Set seed for reproducibility\n",
        "np.random.seed(42)\n",
        "n_logs = 10000\n",
        "\n",
        "print(\"⚙️ Initializing Data Warehouse Architecture Simulation...\")\n",
        "\n",
        "# 1. Generate Dim_Product\n",
        "categories = ['Electronics', 'Home & Kitchen', 'Apparel', 'Automotive', 'Sports & Outdoors']\n",
        "products = [f\"Prod_{i}\" for i in range(1, 101)]\n",
        "product_data = {\n",
        "    'Product_ID': products,\n",
        "    'Product_Name': [f\"Enterprise Item {i}\" for i in range(1, 101)],\n",
        "    'Category': np.random.choice(categories, size=100),\n",
        "    'Unit_Cost': np.random.uniform(10, 250, size=100).round(2)\n",
        "}\n",
        "dim_product = pd.DataFrame(product_data)\n",
        "dim_product['Selling_Price'] = (dim_product['Unit_Cost'] * np.random.uniform(1.3, 2.0, size=100)).round(2)\n",
        "\n",
        "# 2. Generate Dim_Warehouses\n",
        "warehouses = ['WH_North', 'WH_South', 'WH_East', 'WH_West']\n",
        "warehouse_data = {\n",
        "    'Warehouse_ID': warehouses,\n",
        "    'Location_City': ['Delhi', 'Bangalore', 'Kolkata', 'Mumbai'],\n",
        "    'Storage_Capacity_SqFt': [150000, 250000, 180000, 300000],\n",
        "    'Supplier_Lead_Time_Days': [5, 8, 6, 12]  # Average days to get stock from vendor\n",
        "}\n",
        "dim_warehouses = pd.DataFrame(warehouse_data)\n",
        "\n",
        "# 3. Generate Dim_Calendar\n",
        "start_date = datetime(2025, 1, 1)\n",
        "date_list = [start_date + timedelta(days=x) for x in range(365)]\n",
        "calendar_data = {\n",
        "    'Date_Key': [d.strftime('%Y%m%d') for d in date_list],\n",
        "    'Full_Date': date_list,\n",
        "    'Month': [d.strftime('%B') for d in date_list],\n",
        "    'Quarter': [f\"Q{(d.month-1)//3 + 1}\" for d in date_list],\n",
        "    'Fiscal_Year': [2025 for _ in date_list]\n",
        "}\n",
        "dim_calendar = pd.DataFrame(calendar_data)\n",
        "\n",
        "# 4. Generate Fact_Inventory_Daily_Logs\n",
        "fact_data = {\n",
        "    'Log_ID': range(1000001, 1000001 + n_logs),\n",
        "    'Date_Key': np.random.choice(dim_calendar['Date_Key'], size=n_logs),\n",
        "    'Product_ID': np.random.choice(dim_product['Product_ID'], size=n_logs),\n",
        "    'Warehouse_ID': np.random.choice(dim_warehouses['Warehouse_ID'], size=n_logs),\n",
        "    'Units_On_Hand': np.random.randint(50, 1500, size=n_logs),\n",
        "    'Units_Sold': np.random.randint(0, 80, size=n_logs)\n",
        "}\n",
        "fact_inventory = pd.DataFrame(fact_data)\n",
        "# Derived column simulating orders currently in transit from suppliers\n",
        "fact_inventory['Units_On_Order'] = np.where(fact_inventory['Units_On_Hand'] < 200, np.random.randint(200, 500, size=n_logs), 0)\n",
        "\n",
        "# Save relational schema locally in Colab environment\n",
        "dim_product.to_csv(\"dim_product.csv\", index=False)\n",
        "dim_warehouses.to_csv(\"dim_warehouses.csv\", index=False)\n",
        "dim_calendar.to_csv(\"dim_calendar.csv\", index=False)\n",
        "fact_inventory.to_csv(\"fact_inventory_daily_logs.csv\", index=False)\n",
        "\n",
        "print(\"✅ Star Schema Schema Generated Successfully! Saved 4 relational tables (.csv files).\")"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Load relational files to simulate analytical processing\n",
        "fact = pd.read_csv(\"fact_inventory_daily_logs.csv\")\n",
        "prod = pd.read_csv(\"dim_product.csv\")\n",
        "wh = pd.read_csv(\"dim_warehouses.csv\")\n",
        "\n",
        "# Merge context to compute complex supply chain signals\n",
        "merged = fact.merge(prod, on='Product_ID').merge(wh, on='Warehouse_ID')\n",
        "\n",
        "# Calculate Core Analytical Metrics\n",
        "# 1. Average Daily Units Sold per product-warehouse profile\n",
        "avg_daily_sales = merged.groupby(['Product_ID', 'Warehouse_ID'])['Units_Sold'].mean().reset_index(name='Avg_Daily_Sales')\n",
        "merged = merged.merge(avg_daily_sales, on=['Product_ID', 'Warehouse_ID'])\n",
        "\n",
        "# 2. Safety Stock (Buffer to handle spike in demand)\n",
        "merged['Safety_Stock'] = (merged['Avg_Daily_Sales'] * 3).round(0)\n",
        "\n",
        "# 3. Dynamic Reorder Point (ROP) = (Avg Daily Sales * Supplier Lead Time) + Safety Stock\n",
        "merged['Reorder_Point'] = ((merged['Avg_Daily_Sales'] * merged['Supplier_Lead_Time_Days']) + merged['Safety_Stock']).round(0)\n",
        "\n",
        "# 4. Weeks of Supply (WoS) = Current Stock / Weekly Sales Velocity\n",
        "merged['Weekly_Sales_Velocity'] = merged['Avg_Daily_Sales'] * 7\n",
        "merged['Weeks_Of_Supply'] = (merged['Units_On_Hand'] / np.where(merged['Weekly_Sales_Velocity']==0, 1, merged['Weekly_Sales_Velocity'])).round(2)\n",
        "\n",
        "print(\"🧮 Engineering Metrics Complete. Previewing operational signals:\")\n",
        "print(merged[['Product_ID', 'Warehouse_ID', 'Units_On_Hand', 'Reorder_Point', 'Weeks_Of_Supply']].head())"
      ],
